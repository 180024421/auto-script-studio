{
  "name": "Demo 助手",
  "package_id": "com.autoscript.demo",
  "version_code": 2,
  "version_name": "1.0.1",
  "entry": "main.lua",
  "script_language": "lua",
  "permissions": {
    "accessibility": true,
    "screen_capture": true,
    "overlay": true,
    "foreground_service": true
  },
  "runtime": {
    "default_interval_ms": 300,
    "default_yolo_conf": 0.4,
    "ocr_mode": "lazy",
    "input_mode": "auto",
    "screenshot_mode": "media_projection",
    "perf": {
      "opencv_mobile": false,
      "yolo_nnapi": true,
      "yolo_imgsz": 320,
      "capture_cache_ttl_ms": 80
    }
  },
  "license": {
    "enabled": false,
    "api_base": "http://111.229.202.251:8687",
    "app_name": "com.autoscript.demo",
    "skip_on_offline": false
  },
  "jiaoben": {
    "api_base": "http://111.229.202.251:8687",
    "project_id": 1
  },
  "update": {
    "enabled": true,
    "manifest_url": "",
    "check_on_start": true,
    "allow_local_import": false
  },
  "schedule": {
    "enabled": false,
    "daily_time": "08:00"
  },
  "boot": {
    "auto_start": false
  }
}
