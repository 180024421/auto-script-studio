{
  "name": "Demo 助手",
  "package_id": "com.autoscript.demo",
  "version_code": 1,
  "version_name": "1.0.0",
  "entry": "main.lua",
  "script_language": "lua",
  "permissions": {
    "accessibility": true,
    "screen_capture": true,
    "overlay": true,
    "foreground_service": true
  },
  "runtime": {
    "default_interval_ms": 300,
    "default_yolo_conf": 0.35,
    "ocr_mode": "lazy",
    "input_mode": "auto",
    "screenshot_mode": "accessibility",
    "perf": {
      "opencv_mobile": false,
      "yolo_nnapi": false
    }
  },
  "license": {
    "enabled": false,
    "api_base": "https://your-jiaoben-host",
    "app_name": "com.autoscript.demo",
    "skip_on_offline": false
  },
  "update": {
    "enabled": false,
    "manifest_url": "",
    "check_on_start": true
  },
  "schedule": {
    "enabled": false,
    "daily_time": "08:00"
  },
  "boot": {
    "auto_start": false
  }
}
