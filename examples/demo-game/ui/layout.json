{
  "version": 3,
  "enabled": true,
  "panel": {
    "title": "Demo 助手",
    "theme": "light",
    "layout_mode": "free",
    "design_width": 720,
    "design_height": 1280,
    "active_screen": 0,
    "width_mode": "auto",
    "width_dp": 680,
    "height_mode": "wrap",
    "display_mode": "form",
    "auto_collapse_idle_ms": 0,
    "show_on_launch": true,
    "opacity": 0.98,
    "position": "left_center",
    "start_x": 8,
    "start_y": 0,
    "columns": 2,
    "ball_size_dp": 48,
    "show_log": true,
    "log_height_dp": 96,
    "draggable": true,
    "collapsible": true,
    "allow_design": false,
    "start_confirm_collapse": false,
    "height_dp": 1280
  },
  "screens": [
    {
      "title": "基础设置",
      "widgets": [
        {
          "id": "welcome",
          "type": "text",
          "text": "欢迎使用 Demo 助手",
          "text_style": "title",
          "layout_x": 24,
          "layout_y": 20,
          "layout_w": 672,
          "layout_h": 44
        },
        {
          "id": "welcome_hint",
          "type": "text",
          "text": "填写账号与偏好，点击底部「开始」体验脚本",
          "text_style": "hint",
          "layout_x": 24,
          "layout_y": 68,
          "layout_w": 672,
          "layout_h": 36
        },
        {
          "id": "div1",
          "type": "divider",
          "layout_x": 24,
          "layout_y": 112,
          "layout_w": 672,
          "layout_h": 8
        },
        {
          "id": "account",
          "type": "input",
          "label": "账号",
          "placeholder": "请输入游戏账号",
          "default": "demo_user",
          "layout_x": 24,
          "layout_y": 132,
          "layout_w": 672,
          "layout_h": 56
        },
        {
          "id": "password",
          "type": "input",
          "label": "密码",
          "placeholder": "请输入密码",
          "layout_x": 24,
          "layout_y": 200,
          "layout_w": 672,
          "layout_h": 56
        },
        {
          "id": "auto_login",
          "type": "switch",
          "label": "自动登录",
          "default": "true",
          "layout_x": 24,
          "layout_y": 268,
          "layout_w": 672,
          "layout_h": 48
        },
        {
          "id": "div2",
          "type": "divider",
          "layout_x": 24,
          "layout_y": 328,
          "layout_w": 672,
          "layout_h": 8
        },
        {
          "id": "note",
          "type": "text",
          "text": "提示：切换到「运行选项」可调整模式与循环次数",
          "text_style": "hint",
          "layout_x": 24,
          "layout_y": 348,
          "layout_w": 672,
          "layout_h": 40
        }
      ]
    },
    {
      "title": "运行选项",
      "widgets": [
        {
          "id": "mode_title",
          "type": "text",
          "text": "运行策略",
          "text_style": "title",
          "layout_x": 24,
          "layout_y": 20,
          "layout_w": 672,
          "layout_h": 40
        },
        {
          "id": "mode",
          "type": "select",
          "label": "模式",
          "options": ["普通", "极速", "省电"],
          "default": "普通",
          "layout_x": 24,
          "layout_y": 72,
          "layout_w": 672,
          "layout_h": 60
        },
        {
          "id": "priority",
          "type": "radio",
          "label": "优先级",
          "options": ["体验优先", "稳定优先"],
          "default": "稳定优先",
          "layout_x": 24,
          "layout_y": 144,
          "layout_w": 672,
          "layout_h": 80
        },
        {
          "id": "delay_sec",
          "type": "slider",
          "label": "步骤间隔(秒)",
          "default": "2",
          "min": 1,
          "max": 10,
          "layout_x": 24,
          "layout_y": 236,
          "layout_w": 672,
          "layout_h": 56
        },
        {
          "id": "loop_count",
          "type": "stepper",
          "label": "循环次数",
          "default": "3",
          "min": 1,
          "max": 99,
          "layout_x": 24,
          "layout_y": 304,
          "layout_w": 672,
          "layout_h": 52
        },
        {
          "id": "features",
          "type": "multiselect",
          "label": "附加功能",
          "options": ["自动领奖", "自动升级", "异常重试"],
          "default": "异常重试",
          "layout_x": 24,
          "layout_y": 372,
          "layout_w": 672,
          "layout_h": 120
        }
      ]
    }
  ],
  "widgets": [
    {
      "id": "start",
      "type": "start_script",
      "label": "开始运行",
      "color": "#2563EB",
      "layout_x": 24,
      "layout_y": 8,
      "layout_w": 320,
      "layout_h": 48
    },
    {
      "id": "stop",
      "type": "stop_script",
      "label": "停止",
      "color": "#DC2626",
      "layout_x": 360,
      "layout_y": 8,
      "layout_w": 320,
      "layout_h": 48
    }
  ]
}
