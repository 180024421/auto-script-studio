{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auto Script Project",
  "type": "object",
  "required": ["name", "package_id", "entry"],
  "properties": {
    "name": { "type": "string", "description": "应用显示名称" },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Android applicationId"
    },
    "version_code": { "type": "integer", "minimum": 1, "default": 1 },
    "version_name": { "type": "string", "default": "1.0.0" },
    "entry": { "type": "string", "default": "main.lua" },
    "script_language": {
      "type": "string",
      "enum": ["lua", "yaml", "yml", "auto"],
      "default": "lua"
    },
    "icon": { "type": "string", "description": "相对工程根目录的图标 PNG" },
    "permissions": {
      "type": "object",
      "properties": {
        "accessibility": { "type": "boolean", "default": true },
        "screen_capture": { "type": "boolean", "default": true },
        "overlay": { "type": "boolean", "default": true },
        "foreground_service": { "type": "boolean", "default": true }
      }
    },
    "runtime": {
      "type": "object",
      "properties": {
        "default_interval_ms": { "type": "integer", "default": 300 },
        "default_yolo_conf": { "type": "number", "default": 0.35 },
        "default_yolo_model": { "type": "string" },
        "yolo_auto_mask_center": { "type": "boolean", "default": false },
        "device_profile": {
          "type": "object",
          "properties": {
            "serial": { "type": "string" },
            "width": { "type": "integer" },
            "height": { "type": "integer" },
            "label": { "type": "string" }
          }
        },
        "ocr_mode": {
          "type": "string",
          "enum": ["lazy", "eager", "disabled"],
          "default": "lazy"
        },
        "input_mode": {
          "type": "string",
          "enum": ["auto", "accessibility", "root"],
          "default": "auto"
        },
        "screenshot_mode": {
          "type": "string",
          "enum": ["media_projection", "accessibility", "root"],
          "default": "media_projection"
        },
        "auto_run": { "type": "boolean", "default": false },
        "perf": {
          "type": "object",
          "properties": {
            "yolo_nnapi": { "type": "boolean", "default": true },
            "yolo_imgsz": { "type": "integer", "default": 320 },
            "yolo_warmup": { "type": "boolean", "default": true },
            "yolo_seg_fast": { "type": "boolean", "default": false },
            "yolo_max_mask_decode": { "type": "integer", "default": 50 },
            "yolo_backend": { "type": "string", "enum": ["onnx", "ncnn"], "default": "onnx" },
            "capture_cache_ttl_ms": { "type": "integer", "default": 80 },
            "opencv_mobile": { "type": "boolean", "default": false }
          }
        }
      }
    }
  }
}
