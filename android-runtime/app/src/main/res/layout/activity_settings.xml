<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_revert" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="设置"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_surface"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="授权状态"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/authStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="环境授权"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAccessibility"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开启无障碍服务" />

        <Button
            android:id="@+id/btnCapture"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="授权屏幕录制" />

        <Button
            android:id="@+id/btnOverlayPerm"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="授权悬浮窗" />

        <Button
            android:id="@+id/btnLicense"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="卡密验证" />

        <Button
            android:id="@+id/btnShizuku"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="授权 Shizuku 触控" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="脚本热更新"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/updateServerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/chkEnableUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="启用更新检测（连接发版服务器）" />

        <CheckBox
            android:id="@+id/chkAutoUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="检测到更新后自动安装" />

        <CheckBox
            android:id="@+id/chkWifiOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="仅 WiFi 下检测/下载更新" />

        <CheckBox
            android:id="@+id/chkSilentNight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="夜间免打扰（23:00–07:00 不弹窗）" />

        <Button
            android:id="@+id/btnCheckUpdate"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="检查脚本热更新" />

        <Button
            android:id="@+id/btnImportUpdate"
            style="@style/Widget.AutoScript.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="导入本地更新包 (.zip)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="性能配置（project.json）"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/perfConfigText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/card_surface"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="性能统计（最近 + 近20次均值）"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/perfStatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/log_panel"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
