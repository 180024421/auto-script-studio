<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AutoScript" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
    </style>

    <style name="Widget.AutoScript.Button.Primary" parent="Widget.AppCompat.Button.Colored">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="Widget.AutoScript.Button.Secondary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources>
